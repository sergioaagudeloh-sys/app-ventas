rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar si la petición viene de un Administrador con custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Configuración global y Filtros
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Subcolecciones de configuración
    match /config/delivery/messengers/{messengerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Perfiles de clientes y sus subcolecciones (como favoritos)
    // El userId es el número de celular. El doc tiene un campo "uid" con el Firebase Auth UID anónimo.
    match /users/{userId} {
      // Admin: acceso total.
      // Cliente anónimo: puede leer/escribir su propio documento si el campo uid coincide con su Auth UID.
      allow read: if isAdmin() ||
        (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if isAdmin() ||
        (request.auth != null && resource.data.uid == request.auth.uid);
      // Crear nuevo doc: solo requiere estar autenticado (anónimamente) — es el primer login
      allow create: if request.auth != null;
      // Listar y borrar: solo admin
      allow list: if isAdmin();
      allow delete: if isAdmin();

      match /favorites/{favoriteId} {
        // Verifica que el uid del doc padre coincida con el uid del solicitante
        allow read, write: if isAdmin() ||
          (request.auth != null &&
           get(/databases/$(database)/documents/users/$(userId)).data.uid == request.auth.uid);
      }
    }

    // Catálogo e Inventario
    match /products/{document} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['variantes', 'salesCount', 'updatedAt'])
      );
    }
    match /categories/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Pedidos (Retail y Mayoristas)
    match /orders/{document} {
      allow create: if true;
      allow read: if isAdmin() || 
                  (resource.data.cliente.celular != null) ||
                  (resource.data.trackingToken != null);
      allow update: if isAdmin() || (
        resource.data.cliente.celular != null &&
        (
          (request.resource.data.estado == 'cancelado' && resource.data.estado == 'pendiente') ||
          (request.resource.data.ocultoCliente == true)
        )
      );
      allow delete: if isAdmin();
    }
    
    match /wholesaleOrders/{document} {
      allow create: if true;
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow update, delete: if isAdmin();
    }

    // Créditos / Fiados
    match /credits/{document} {
      allow read: if isAdmin() ||
                  (request.auth != null && (
                    resource.data.clienteUid == request.auth.uid ||
                    resource.data.clienteCelular == request.auth.token.phone_number
                  ));
      allow write: if isAdmin();
    }

    // Publicidad y Promociones
    match /ads/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Cupones
    match /coupons/{document} {
      allow read, list: if true;
      allow write, delete: if isAdmin();
    }

    // Garantías y Reclamos
    match /claims/{document} {
      allow create: if true;
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow update, delete: if isAdmin();
    }

    // [NUEVO] Centro de Notificaciones Centralizado
    match /notifications/{document} {
      allow read, write: if true;
    }

    // [NUEVO] Registro de Tokens FCM (Dispositivos)
    match /fcmTokens/{document} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Notificaciones del Cliente (Legacy compatibility)
    match /clientNotifications/{document} {
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow create: if true;
      allow update: if isAdmin() || (resource.data.clienteCelular != null);
      allow delete: if isAdmin();
    }

    // Configuración y PINs de empleados (Altamente sensible)
    match /employees/{employeeId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Mesas de servicio en salón
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Órdenes en cola de producción
    match /production/{prodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Entregas y despachos
    match /deliveries/{deliveryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Kardex y Movimientos de Stock
    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Historial de Accesos y Sesiones QR
    match /accessLogs/{logId} {
      allow read: if isAdmin();
      allow create, update: if true;
    }

    // Analíticas de Códigos QR
    match /qrAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Telemetría y Analíticas
    match /trackingAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
