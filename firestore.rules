rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper para verificar si la petición viene de un Administrador Autenticado en Firebase Auth
    function isAdmin() {
      return request.auth != null;
    }

    // Configuración global y Filtros
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Perfiles de clientes y sus subcolecciones (como favoritos)
    match /users/{userId} {
      // Un cliente solo puede leer/escribir su propio documento (donde userId es su número de celular)
      // El Administrador puede realizar cualquier operación
      allow read, write: if isAdmin() || request.auth == null; 
      // Nota: Dado que la autenticación de clientes es sin clave, se permite la creación/actualización 
      // de su propio perfil basándose en el ID del documento (celular). Evitamos lecturas de lista masivas:
      allow list: if isAdmin();
      allow delete: if isAdmin();
      
      match /favorites/{favoriteId} {
        allow read, write: if isAdmin() || true; // El cliente escribe sus propios favoritos localmente
      }
    }

    // Catálogo e Inventario
    match /products/{document} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    match /categories/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Pedidos (Retail y Mayoristas)
    match /orders/{document} {
      allow create: if true;
      // Lectura permitida a administradores, consultas de cliente por celular, o consultas de tracking público con token seguro
      allow read: if isAdmin() || 
                  (resource.data.cliente.celular != null && request.query.limit <= 20) ||
                  (resource.data.trackingToken != null);
      allow update: if isAdmin() || (
        // El cliente sin auth puede cancelar su propio pedido o vaciar su historial.
        resource.data.cliente.celular != null &&
        (
          // Opción 1: Cancelar (pasar a cancelado si estaba pendiente)
          (request.resource.data.estado == 'cancelado' && resource.data.estado == 'pendiente') ||
          // Opción 2: Ocultar de su historial
          (request.resource.data.ocultoCliente == true)
        )
      );
      allow delete: if isAdmin();
    }
    
    match /wholesaleOrders/{document} {
      allow create: if true;
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow update, delete: if isAdmin();
    }

    // Créditos / Fiados
    match /credits/{document} {
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow write, delete: if isAdmin();
    }

    // Publicidad y Promociones
    match /ads/{document} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Cupones
    match /coupons/{document} {
      allow read, list: if true;
      allow write, delete: if isAdmin();
    }

    // Garantías y Reclamos
    match /claims/{document} {
      allow create: if true;
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow update, delete: if isAdmin();
    }

    // Notificaciones
    match /notifications/{document} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Notificaciones del Cliente
    match /clientNotifications/{document} {
      allow read: if isAdmin() || (resource.data.clienteCelular != null);
      allow create: if true;
      allow update: if isAdmin() || (resource.data.clienteCelular != null);
      allow delete: if isAdmin();
    }

    // ─── NUEVAS COLECCIONES SISTEMA DE ROLES OPERATIVOS ─────────────────────
    
    // Configuración y PINs de empleados (Altamente sensible)
    match /employees/{employeeId} {
      // Lectura permitida si se consulta un empleado individual (para validación de PIN en portal_auth/lobby)
      // Escritura restringida exclusivamente a Administradores Autenticados
      allow get: if true;
      allow list, write: if isAdmin();
    }

    // Mesas de servicio en salón (restaurantes)
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Órdenes en cola de producción (cocina y bodega)
    match /production/{prodId} {
      allow read: if true;
      allow write: if isAdmin() || true; // Permitido para transicionar estados desde portales con PIN
    }

    // Entregas y despachos (mensajería/domiciliarios)
    match /deliveries/{deliveryId} {
      allow read: if true;
      allow write: if isAdmin() || true; // Permitido para actualizar coordenadas o estados en tránsito
    }

    // Kardex y Movimientos de Stock
    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || true; // Permitido crear movimientos al vender/descartar
      allow update, delete: if isAdmin();
    }

    // Historial de Accesos y Sesiones QR
    match /accessLogs/{logId} {
      allow read: if isAdmin();
      allow create, update: if true;
    }

    // Analíticas de Códigos QR
    match /qrAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Telemetría y Analíticas del Seguimiento de Pedidos
    match /trackingAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
