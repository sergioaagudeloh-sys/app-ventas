rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Configuración global y Filtros
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Perfiles de clientes y sus subcolecciones (como favoritos)
    match /users/{userId} {
      allow read, write: if true;
      
      match /favorites/{favoriteId} {
        allow read, write: if true;
      }
    }

    // Catálogo e Inventario
    match /products/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pedidos (Retail y Mayoristas)
    match /orders/{document} {
      allow read, create: if true;
      allow update: if request.auth != null || (
        // El cliente sin auth puede cancelar su propio pedido o vaciar su historial
        request.resource.data.cliente.celular == resource.data.cliente.celular &&
        (
          // Opción 1: Cancelar (pasar a cancelado si estaba pendiente)
          (request.resource.data.estado == 'cancelado' && resource.data.estado == 'pendiente') ||
          // Opción 2: Ocultar de su historial
          (request.resource.data.ocultoCliente == true)
        )
      );
      allow delete: if request.auth != null;
    }
    match /wholesaleOrders/{document} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Créditos / Fiados
    match /credits/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Publicidad y Promociones
    match /ads/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
